@inherits LayoutComponentBase

<div class="app-wrapper">
    <div class="sidebar">
        <div class="sidebar-header">
            <a class="sidebar-brand" href="/">
                <svg class="logo-icon" style="width: 24px; height: 24px; color: var(--primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                    <line x1="12" y1="22.08" x2="12" y2="12"/>
                </svg>
                <span>WMS Portal</span>
            </a>
        </div>
        <NavMenu />
    </div>

    <div class="main-content">
        <header class="top-bar">
            <div class="top-left">
                <span style="font-weight: 500; font-size: 15px; color: var(--text-muted);">Warehouse Management System</span>
            </div>
            
            <div class="top-right" style="display: flex; align-items: center; gap: 16px;">
                <AuthorizeView>
                    <Authorized>
                        <div style="text-align: right;">
                            <div style="font-weight: 600; font-size: 14px; color: var(--text-main);">@context.User.Identity?.Name</div>
                            <div style="font-size: 11px; color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">Admin</div>
                        </div>
                        <a href="logout" class="btn btn-sm" style="border: 1px solid var(--card-border); color: var(--text-muted); font-size: 13px; border-radius: 6px; padding: 6px 12px; text-decoration: none; transition: background-color 0.2s;">
                            Sign Out
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="login" class="btn btn-sm btn-primary">Sign In</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <main class="page-body">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
