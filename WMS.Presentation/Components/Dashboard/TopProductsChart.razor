@inject IMediator Mediator

<div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; min-height: 380px;">
    <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); display: flex; align-items: center; gap: 8px;">
        <svg style="width: 18px; height: 18px; color: var(--success);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
        </svg>
        Top Products by Transactions
    </h3>
    
    @if (loading)
    {
        <div style="display: flex; justify-content: center; align-items: center; height: 280px;">
            <div class="spinner-border text-primary" role="status" style="width: 2rem; height: 2rem; color: var(--primary) !important;">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @if (chartData == null || !chartData.Any())
        {
            <div style="display: flex; justify-content: center; align-items: center; height: 280px; color: var(--text-muted);">
                No transaction data available.
            </div>
        }
        else
        {
            <ApexChart TItem="TopProductDto"
                       Options="chartOptions"
                       Height="280">
                
                <ApexPointSeries TItem="TopProductDto"
                                 Items="chartData"
                                 Name="Movements"
                                 SeriesType="SeriesType.Donut"
                                 XValue="@(e => e.ProductCode)"
                                 YValue="@(e => e.MovementCount)" />
            </ApexChart>
        }
    }
</div>

@code {
    private bool loading = true;
    private List<TopProductDto>? chartData;
    private ApexChartOptions<TopProductDto> chartOptions = new()
    {
        Theme = new Theme { Mode = Mode.Dark, Palette = PaletteType.Palette3 },
        Chart = new Chart 
        { 
            Background = "transparent",
            Toolbar = new Toolbar { Show = false }
        },
        Legend = new Legend
        {
            Position = LegendPosition.Bottom,
            Labels = new LegendLabels { Colors = "#94a3b8" }
        }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Mediator.Send(new GetTopProductsQuery(10));
            if (result.IsSuccess)
            {
                chartData = result.Value;
            }
        }
        catch
        {
            // Fallback
        }
        finally
        {
            loading = false;
        }
    }
}
