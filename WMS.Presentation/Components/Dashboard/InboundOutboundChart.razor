@inject IMediator Mediator

<div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; min-height: 380px;">
    <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); display: flex; align-items: center; gap: 8px;">
        <svg style="width: 18px; height: 18px; color: var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
        </svg>
        Fulfillment Volume (Last 30 Days)
    </h3>
    
    @if (loading)
    {
        <div style="display: flex; justify-content: center; align-items: center; height: 280px;">
            <div class="spinner-border text-primary" role="status" style="width: 2rem; height: 2rem; color: var(--primary) !important;">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        @if (chartData == null || !chartData.Any())
        {
            <div style="display: flex; justify-content: center; align-items: center; height: 280px; color: var(--text-muted);">
                No movement history available.
            </div>
        }
        else
        {
            <ApexChart TItem="InboundOutboundVolumeDto"
                       Options="chartOptions"
                       Height="280">
                
                <ApexPointSeries TItem="InboundOutboundVolumeDto"
                                 Items="chartData"
                                 Name="Inbound (Receipts)"
                                 SeriesType="SeriesType.Area"
                                 XValue="@(e => e.Date.ToString("yyyy-MM-dd"))"
                                 YValue="@(e => e.InboundQuantity)"
                                 Color="#0ea5e9" />
                                 
                <ApexPointSeries TItem="InboundOutboundVolumeDto"
                                 Items="chartData"
                                 Name="Outbound (Issues)"
                                 SeriesType="SeriesType.Area"
                                 XValue="@(e => e.Date.ToString("yyyy-MM-dd"))"
                                 YValue="@(e => e.OutboundQuantity)"
                                 Color="#10b981" />
            </ApexChart>
        }
    }
</div>

@code {
    private bool loading = true;
    private List<InboundOutboundVolumeDto>? chartData;
    private ApexChartOptions<InboundOutboundVolumeDto> chartOptions = new()
    {
        Theme = new Theme { Mode = Mode.Dark },
        Chart = new Chart 
        { 
            Background = "transparent",
            Toolbar = new Toolbar { Show = false }
        },
        Grid = new Grid 
        { 
            BorderColor = "rgba(255, 255, 255, 0.05)" 
        },
        Xaxis = new XAxis
        {
            Labels = new XAxisLabels { Style = new AxisLabelStyle { Colors = "#94a3b8" } }
        },
        Yaxis = new List<YAxis>
        {
            new YAxis
            {
                Labels = new YAxisLabels { Style = new AxisLabelStyle { Colors = "#94a3b8" } }
            }
        },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 2 }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Mediator.Send(new GetInboundOutboundVolumeQuery());
            if (result.IsSuccess)
            {
                chartData = result.Value;
            }
        }
        catch
        {
            // Fallback
        }
        finally
        {
            loading = false;
        }
    }
}
