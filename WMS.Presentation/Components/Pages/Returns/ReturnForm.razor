@page "/returns/new"
@attribute [Authorize]
@inject IMediator Mediator
@inject IRepository<WMS.Domain.Entities.MasterData.Product> ProductRepository
@inject IRepository<WMS.Domain.Entities.MasterData.Location> LocationRepository
@inject NavigationManager Navigation

<PageTitle>WMS - New Return Order</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/returns" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Returns
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">
        New @(IsCustomerReturn ? "Customer Return" : "Supplier Return")
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">
        Draft a new @(IsCustomerReturn ? "incoming customer return based on a Goods Issue" : "outgoing supplier return based on a Goods Receipt").
    </p>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
            <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>@errorMessage</span>
        </div>
    }

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px; align-items: start;">
        <!-- Left Panel: General info -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Fulfillment Reference</h3>
            
            <div class="form-group">
                <label style="color: var(--text-muted); font-size: 14px; font-weight: 600;">
                    @(IsCustomerReturn ? "Original Goods Issue (GI) Reference Number" : "Original Goods Receipt (GR) Reference Number")
                </label>
                <div style="margin-top: 8px;">
                    <input type="text" class="form-control" @bind="ReferenceNo" placeholder="@(IsCustomerReturn ? "e.g. GI-202606-00001" : "e.g. GR-202606-00001")" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; outline: none; width: 100%; box-sizing: border-box;" />
                </div>
            </div>

            <div class="form-group" style="margin-top: 20px;">
                <label style="color: var(--text-muted); font-size: 14px; font-weight: 600;">Note / Reason for Return</label>
                <div style="margin-top: 8px;">
                    <textarea class="form-control" @bind="Note" rows="3" placeholder="Enter return context, inspection notes or reason..." style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; width: 100%; box-sizing: border-box; outline: none; resize: vertical;"></textarea>
                </div>
            </div>
        </div>

        <!-- Right Panel: Summary -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; min-height: 145px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Return Summary</h3>
            
            <div style="display: flex; flex-direction: column; gap: 16px;">
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Status:</span>
                    <span style="font-weight: 600; color: #94a3b8;">Pending</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Total Line Items:</span>
                    <span style="font-weight: 600; color: var(--text-main);">@items.Count</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Items Section -->
    <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">
            <h3 style="font-size: 16px; font-weight: 700; margin: 0; color: var(--text-main);">Return Items</h3>
            <button type="button" class="btn btn-sm" @onclick="AddItem" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(255, 255, 255, 0.05); padding: 8px 16px; border-radius: 6px; font-weight: 600; font-size: 13px; display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
                <svg style="width: 14px; height: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add Item
            </button>
        </div>

        <div style="overflow-x: auto;">
            <table class="wms-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr>
                        <th style="width: 40%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Product</th>
                        <th style="width: 30%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Bin Location</th>
                        <th style="width: 15%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Quantity</th>
                        <th style="width: 15%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 24px; color: var(--text-muted); border-bottom: 1px solid var(--card-border);">
                                No items added yet. Click "Add Item" to start drafting.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (int i = 0; i < items.Count; i++)
                        {
                            var index = i;
                            var item = items[index];
                            <tr>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                    <select class="form-control" @bind="item.ProductId" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 100%; cursor: pointer;">
                                        <option value="">-- Select Product --</option>
                                        @if (products != null)
                                        {
                                            foreach (var p in products)
                                            {
                                                <option value="@p.Id">@p.Name (@p.Code)</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                    <select class="form-control" @bind="item.LocationId" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 100%; cursor: pointer;">
                                        <option value="">-- Select Bin --</option>
                                        @if (locations != null)
                                        {
                                            foreach (var loc in locations)
                                            {
                                                <option value="@loc.Id">@loc.Barcode</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right;">
                                    <input type="number" step="any" class="form-control" @bind="item.Quantity" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 100px; text-align: right; display: inline-block;" />
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: center;">
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveItem(index)" style="padding: 6px 12px; border-radius: 6px; font-size: 13px; cursor: pointer; border: 1px solid rgba(239, 68, 68, 0.2); color: #fca5a5; background: rgba(239, 68, 68, 0.1);">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Actions -->
    <div style="display: flex; gap: 12px; justify-content: flex-end;">
        <a href="/returns" class="btn" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(15, 23, 42, 0.4); padding: 10px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 15px;">
            Cancel
        </a>
        <button type="button" class="btn btn-primary" @onclick="SaveReturn" style="padding: 10px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; cursor: pointer;">
            Save Return Order
        </button>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public string? Type { get; set; }

    private bool IsCustomerReturn => string.Equals(Type, "Customer", StringComparison.OrdinalIgnoreCase) || string.IsNullOrEmpty(Type);

    private bool loading = true;
    private string? errorMessage;

    private string ReferenceNo = string.Empty;
    private string? Note;

    private List<FormItem> items = new();
    private IReadOnlyList<WMS.Domain.Entities.MasterData.Product>? products;
    private IReadOnlyList<WMS.Domain.Entities.MasterData.Location>? locations;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            products = await ProductRepository.FindAsync(p => p.IsActive, CancellationToken.None);
            locations = await LocationRepository.FindAsync(l => l.IsActive, CancellationToken.None);
        }
        catch (Exception ex)
        {
            errorMessage = $"Error initializing: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void AddItem()
    {
        items.Add(new FormItem());
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < items.Count)
        {
            items.RemoveAt(index);
        }
    }

    private async Task SaveReturn()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(ReferenceNo))
        {
            errorMessage = "Reference number is required.";
            return;
        }

        if (!items.Any())
        {
            errorMessage = "At least one return item is required.";
            return;
        }

        foreach (var item in items)
        {
            if (item.ProductId == Guid.Empty)
            {
                errorMessage = "All items must have a valid product selected.";
                return;
            }
            if (item.LocationId == Guid.Empty)
            {
                errorMessage = "All items must have a valid bin location selected.";
                return;
            }
            if (item.Quantity <= 0)
            {
                errorMessage = "All quantities must be greater than 0.";
                return;
            }
        }

        var inputItems = items.Select(i => new CreateReturnItemInput(i.ProductId, i.LocationId, i.Quantity, i.Note)).ToList();

        if (IsCustomerReturn)
        {
            var result = await Mediator.Send(new CreateCustomerReturnCommand(ReferenceNo, Note, inputItems));
            if (result.IsSuccess)
            {
                Navigation.NavigateTo($"/returns/{result.Value}");
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        else
        {
            var result = await Mediator.Send(new CreateSupplierReturnCommand(ReferenceNo, Note, inputItems));
            if (result.IsSuccess)
            {
                Navigation.NavigateTo($"/returns/{result.Value}");
            }
            else
            {
                errorMessage = result.Error;
            }
        }
    }

    public class FormItem
    {
        public Guid ProductId { get; set; }
        public Guid LocationId { get; set; }
        public decimal Quantity { get; set; } = 1;
        public string? Note { get; set; }
    }
}
