@page "/settings/change-password"
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using WMS.Domain.Entities.Identity
@inject UserManager<AppUser> UserManager
@inject ICurrentUserService CurrentUserService

<PageTitle>WMS - Change Password</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Dashboard
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Change Password</h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">Update your account credentials to keep your profile secure.</p>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 16px; border-radius: 8px; color: #a7f3d0;">
        <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
        </svg>
        <span>@successMessage</span>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
        <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>@errorMessage</span>
    </div>
}

<div style="max-width: 600px; background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
    <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Security Credentials</h3>
    
    <div style="display: flex; flex-direction: column; gap: 20px;">
        <div class="form-group">
            <label style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: block;">Current Password</label>
            <input type="password" class="form-control" @bind="currentPassword" placeholder="Enter current security password" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 14px; outline: none; width: 100%; box-sizing: border-box;" />
        </div>

        <div class="form-group">
            <label style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: block;">New Password</label>
            <input type="password" class="form-control" @bind="newPassword" placeholder="Minimum 8 characters with numbers & symbols" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 14px; outline: none; width: 100%; box-sizing: border-box;" />
        </div>

        <div class="form-group">
            <label style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: block;">Confirm New Password</label>
            <input type="password" class="form-control" @bind="confirmPassword" placeholder="Re-enter new password" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 14px; outline: none; width: 100%; box-sizing: border-box;" />
        </div>
    </div>
</div>

<div style="display: flex; gap: 12px; justify-content: flex-start; max-width: 600px;">
    <button class="btn btn-primary" @onclick="ChangePasswordAsync" style="padding: 10px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; cursor: pointer; width: 100%;">
        Update Password
    </button>
</div>

@code {
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmPassword = string.Empty;

    private string? successMessage;
    private string? errorMessage;

    private async Task ChangePasswordAsync()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMessage = "All fields are required.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "New password and confirmation do not match.";
            return;
        }

        if (newPassword.Length < 8)
        {
            errorMessage = "Password must be at least 8 characters long.";
            return;
        }

        var userId = CurrentUserService.UserId;
        var user = await UserManager.FindByIdAsync(userId?.ToString() ?? string.Empty);
        if (user == null)
        {
            errorMessage = "Logged in user context could not be resolved.";
            return;
        }

        var result = await UserManager.ChangePasswordAsync(user, currentPassword, newPassword);
        if (result.Succeeded)
        {
            successMessage = "Your password has been changed successfully.";
            currentPassword = string.Empty;
            newPassword = string.Empty;
            confirmPassword = string.Empty;
        }
        else
        {
            errorMessage = string.Join("; ", result.Errors.Select(e => e.Description));
        }
    }
}
