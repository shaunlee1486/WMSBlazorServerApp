@page "/logout"
@attribute [Authorize]
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>WMS Sign Out</PageTitle>

<div class="login-container">
    <div class="glass-card text-center" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <h2>Signing Out</h2>
        <p class="text-muted" style="margin-top: 8px;">Please wait while we clear your session...</p>
        
        <form id="logoutForm" method="post" action="/api/auth/logout" style="display:none">
            <AntiforgeryToken />
        </form>
    </div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500); // Visual polish
            await JS.InvokeVoidAsync("eval", "document.getElementById('logoutForm').submit()");
        }
    }
}
