@page "/users/new"
@page "/users/{Id:guid}/edit"
@attribute [Authorize(Roles = "Admin")]
@inject IMediator Mediator
@inject IIdentityService IdentityService
@inject NavigationManager Navigation

<PageTitle>WMS - User Account Form</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/users" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Accounts
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">
        @(IsEditMode ? "Edit User Account" : "Create User Account")
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">
        @(IsEditMode ? "Update details, assign system permissions, and reset user passwords." : "Register a new operator and configure role accesses.")
    </p>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
            <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>@errorMessage</span>
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 16px; border-radius: 8px; color: #a7f3d0;">
            <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>@successMessage</span>
        </div>
    }

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start; margin-bottom: 24px;">
        <!-- Left: Account Details -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">General Credentials</h3>
            
            <div style="display: flex; flex-direction: column; gap: 20px;">
                <div class="form-group">
                    <label style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: block;">Email Address / Username</label>
                    <input type="email" class="form-control" @bind="Email" disabled="@IsEditMode" placeholder="e.g. employee@company.com" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; outline: none; width: 100%; box-sizing: border-box;" />
                </div>

                <div class="form-group">
                    <label style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: block;">Full Name</label>
                    <input type="text" class="form-control" @bind="FullName" placeholder="e.g. John Doe" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; outline: none; width: 100%; box-sizing: border-box;" />
                </div>

                @if (!IsEditMode)
                {
                    <div class="form-group">
                        <label style="color: var(--text-muted); font-size: 14px; font-weight: 600; margin-bottom: 8px; display: block;">Temporary Password</label>
                        <input type="password" class="form-control" @bind="Password" placeholder="Minimum 8 characters, letters & symbols" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; outline: none; width: 100%; box-sizing: border-box;" />
                    </div>
                }

                <div class="form-group" style="display: flex; align-items: center; gap: 10px; margin-top: 10px;">
                    <input type="checkbox" id="isActiveCheck" @bind="IsActive" style="width: 18px; height: 18px; cursor: pointer; accent-color: var(--primary);" />
                    <label for="isActiveCheck" style="color: var(--text-main); font-size: 15px; font-weight: 500; cursor: pointer;">Enable User Account (Active)</label>
                </div>
            </div>
        </div>

        <!-- Right: Role Permissions & Reset -->
        <div style="display: flex; flex-direction: column; gap: 24px;">
            <!-- Role configuration -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Permissions (Roles)</h3>
                
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @if (availableRoles != null)
                    {
                        foreach (var role in availableRoles)
                        {
                            var roleName = role;
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <input type="checkbox" id="role-@roleName" checked="@SelectedRoles.Contains(roleName)" @onchange="(e) => ToggleRole(roleName, e.Value)" style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary);" />
                                <label for="role-@roleName" style="color: var(--text-main); font-size: 14px; font-weight: 500; cursor: pointer;">@roleName</label>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Reset password (Edit Mode only) -->
            @if (IsEditMode)
            {
                <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                    <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Administrative Override</h3>
                    
                    <div class="form-group">
                        <label style="color: var(--text-muted); font-size: 13px; font-weight: 600; margin-bottom: 8px; display: block;">Reset Password</label>
                        <input type="password" class="form-control" @bind="newOverridePassword" placeholder="Enter new password" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 100%; box-sizing: border-box;" />
                        <button type="button" class="btn" @onclick="OverridePassword" style="margin-top: 10px; width: 100%; border: 1px solid var(--card-border); color: var(--text-main); background: rgba(255, 255, 255, 0.05); padding: 8px; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer;">
                            Apply Password
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Actions -->
    <div style="display: flex; gap: 12px; justify-content: flex-end;">
        <a href="/users" class="btn" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(15, 23, 42, 0.4); padding: 10px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 15px;">
            Cancel
        </a>
        <button type="button" class="btn btn-primary" @onclick="SaveUser" style="padding: 10px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; cursor: pointer;">
            Save User Account
        </button>
    </div>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;

    private bool loading = true;
    private string? errorMessage;
    private string? successMessage;

    private string Email = string.Empty;
    private string FullName = string.Empty;
    private string Password = string.Empty;
    private bool IsActive = true;

    private List<string> SelectedRoles = new();
    private List<string>? availableRoles;

    private string newOverridePassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            availableRoles = await IdentityService.GetAllRolesAsync(CancellationToken.None);

            if (IsEditMode)
            {
                var result = await Mediator.Send(new GetUserByIdQuery(Id!.Value));
                if (result.IsSuccess)
                {
                    Email = result.Value.Email;
                    FullName = result.Value.FullName;
                    IsActive = result.Value.IsActive;
                    SelectedRoles = result.Value.Roles;
                }
                else
                {
                    errorMessage = result.Error;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error initializing form: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void ToggleRole(string roleName, object? checkedValue)
    {
        bool isChecked = checkedValue is bool b && b;
        if (isChecked)
        {
            if (!SelectedRoles.Contains(roleName))
            {
                SelectedRoles.Add(roleName);
            }
        }
        else
        {
            SelectedRoles.Remove(roleName);
        }
    }

    private async Task SaveUser()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(FullName))
        {
            errorMessage = "Full Name is required.";
            return;
        }

        if (IsEditMode)
        {
            var result = await Mediator.Send(new UpdateUserCommand(Id!.Value, Email, FullName, IsActive, SelectedRoles));
            if (result.IsSuccess)
            {
                Navigation.NavigateTo("/users");
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        else
        {
            if (string.IsNullOrWhiteSpace(Email))
            {
                errorMessage = "Email address is required.";
                return;
            }
            if (string.IsNullOrWhiteSpace(Password) || Password.Length < 8)
            {
                errorMessage = "Password is required and must be at least 8 characters long.";
                return;
            }

            var result = await Mediator.Send(new CreateUserCommand(Email, Password, FullName, SelectedRoles));
            if (result.IsSuccess)
            {
                Navigation.NavigateTo("/users");
            }
            else
            {
                errorMessage = result.Error;
            }
        }
    }

    private async Task OverridePassword()
    {
        errorMessage = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(newOverridePassword) || newOverridePassword.Length < 8)
        {
            errorMessage = "Override password must be at least 8 characters long.";
            return;
        }

        var result = await Mediator.Send(new ResetUserPasswordCommand(Id!.Value, newOverridePassword));
        if (result.IsSuccess)
        {
            successMessage = "Password reset successfully.";
            newOverridePassword = string.Empty;
        }
        else
        {
            errorMessage = result.Error;
        }
    }
}
