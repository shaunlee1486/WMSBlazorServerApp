@page "/outbound/pick-lists/{Id:guid}"
@attribute [Authorize(Roles = "Admin,WarehouseManager,Picker,Viewer")]
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject UserManager<WMS.Domain.Entities.Identity.AppUser> UserManager
@inject ICurrentUserService CurrentUserService

<PageTitle>WMS - Picking Checklist</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/outbound/pick-lists" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Pick Lists
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">
        Picking Checklist
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">
        Fulfill inventory dispatches line-by-line. Confirm barcodes and quantities.
    </p>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (pl == null)
    {
        <div class="alert alert-danger" style="display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
            <svg class="alert-icon" style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>Pick list not found.</span>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
                <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>@errorMessage</span>
            </div>
        }

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px; align-items: start;">
            <!-- Left Panel: PL General Info -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Picking Header Details</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Pick List Number</span>
                        <div style="margin-top: 6px; font-family: monospace; font-size: 16px; font-weight: 700; color: var(--text-main);">@pl.PickListNumber</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Linked Sales Order</span>
                        <div style="margin-top: 6px; font-family: monospace; font-size: 15px; color: var(--text-main);">
                            <a href="/outbound/sales-orders/@pl.SalesOrderId" style="color: var(--primary); text-decoration: none;">@pl.SONumber</a>
                        </div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Customer</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@pl.CustomerName</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Assigned Picker</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@assignedPickerName</div>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Lifecycle Action Card -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Fulfillment Stage</h3>
                
                <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="color: var(--text-muted);">Status:</span>
                        <span class="badge" style="background-color: @GetStatusBgColor(pl.Status); color: @GetStatusTextColor(pl.Status); padding: 6px 12px; border-radius: 9999px; font-size: 11px; font-weight: 700; text-transform: uppercase; border: 1px solid @GetStatusBorderColor(pl.Status)">
                            @pl.Status
                        </span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Lines Completed:</span>
                        <span style="font-weight: 700; color: var(--text-main);">
                            @pl.Items.Count(i => i.PickedQty >= i.RequiredQty) / @pl.Items.Count
                        </span>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @if (pl.Status == "Pending")
                    {
                        <button class="btn btn-primary" @onclick="StartPicking" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; width: 100%;">
                            Start Picking Task
                        </button>
                    }
                    @if (pl.Status == "InProgress")
                    {
                        <button class="btn" @onclick="CompletePicking" style="padding: 12px; border-radius: 8px; border: none; background: linear-gradient(135deg, var(--success), #059669); color: #fff; font-weight: 600; font-size: 15px; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
                            <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Complete Picking
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Items to Dispatch</h3>
            
            <table class="wms-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr>
                        <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Product</th>
                        <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Location Bin</th>
                        <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Required Qty</th>
                        <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Picked Qty</th>
                        @if (pl.Status == "InProgress")
                        {
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: center; width: 180px;">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pl.Items)
                    {
                        <tr>
                            <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                <div style="font-weight: 600; color: var(--text-main);">@item.ProductName</div>
                                <div style="font-family: monospace; font-size: 12px; color: var(--text-muted); margin-top: 4px;">@item.ProductCode</div>
                            </td>
                            <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                <span class="badge" style="background: rgba(99, 102, 241, 0.1); border: 1px solid rgba(99, 102, 241, 0.2); color: #818cf8; font-weight: 600; padding: 4px 8px; border-radius: 6px; font-size: 12px;">
                                    @item.LocationName
                                </span>
                                <div style="font-family: monospace; font-size: 11px; color: var(--text-muted); margin-top: 4px;">BC: @item.LocationBarcode</div>
                            </td>
                            <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right;">@item.RequiredQty.ToString("N4")</td>
                            <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right; font-weight: 600; color: @(item.PickedQty >= item.RequiredQty ? "#34d399" : (item.PickedQty > 0 ? "#fbbf24" : "var(--text-muted)"));">
                                @item.PickedQty.ToString("N4")
                            </td>
                            @if (pl.Status == "InProgress")
                            {
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: center;">
                                    <div style="display: flex; gap: 8px; align-items: center; justify-content: center;">
                                        <button class="btn btn-sm" @onclick="() => AutofillItem(item)" style="padding: 6px 10px; border-radius: 6px; border: 1px solid var(--card-border); color: var(--text-main); background: rgba(255, 255, 255, 0.05); font-size: 12px;">
                                            Max
                                        </button>
                                        <input type="number" step="any" class="form-control" @bind="item.PickedQty" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 6px 8px; font-size: 13px; outline: none; width: 70px; text-align: right;" />
                                        <button class="btn btn-sm btn-primary" @onclick="() => SaveItemPickedQty(item)" style="padding: 6px 12px; border-radius: 6px; font-size: 12px; font-weight: 600;">
                                            Save
                                        </button>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool loading = true;
    private string? errorMessage;
    private WMS.Application.Features.PickList.DTOs.PickListDto? pl;
    private string assignedPickerName = "Unassigned";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            var result = await Mediator.Send(new GetPickListByIdQuery(Id));
            if (result.IsSuccess)
            {
                pl = result.Value;
                if (pl.AssignedTo.HasValue)
                {
                    var user = await UserManager.FindByIdAsync(pl.AssignedTo.Value.ToString());
                    assignedPickerName = user != null ? (string.IsNullOrWhiteSpace(user.FullName) ? user.UserName! : user.FullName) : "Unknown Operator";
                }
                else
                {
                    assignedPickerName = "Unassigned";
                }
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading pick list checklist: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task StartPicking()
    {
        errorMessage = null;
        var currentUserId = CurrentUserService.UserId;
        var result = await Mediator.Send(new AssignPickListCommand(Id, currentUserId));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private void AutofillItem(WMS.Application.Features.PickList.DTOs.PickListItemDto item)
    {
        item.PickedQty = item.RequiredQty;
    }

    private async Task SaveItemPickedQty(WMS.Application.Features.PickList.DTOs.PickListItemDto item)
    {
        errorMessage = null;
        var result = await Mediator.Send(new UpdatePickedQtyCommand(Id, item.Id, item.PickedQty));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private async Task CompletePicking()
    {
        errorMessage = null;
        var result = await Mediator.Send(new CompletePickListCommand(Id));
        if (result.IsSuccess)
        {
            Navigation.NavigateTo("/outbound/pick-lists");
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private string GetStatusBgColor(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "rgba(148, 163, 184, 0.1)",
            "inprogress" => "rgba(59, 130, 246, 0.1)",
            "completed" => "rgba(16, 185, 129, 0.1)",
            "cancelled" => "rgba(239, 68, 68, 0.1)",
            _ => "rgba(255, 255, 255, 0.05)"
        };
    }

    private string GetStatusTextColor(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "#94a3b8",
            "inprogress" => "#60a5fa",
            "completed" => "#34d399",
            "cancelled" => "#fca5a5",
            _ => "var(--text-muted)"
        };
    }

    private string GetStatusBorderColor(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "rgba(148, 163, 184, 0.2)",
            "inprogress" => "rgba(59, 130, 246, 0.2)",
            "completed" => "rgba(16, 185, 129, 0.2)",
            "cancelled" => "rgba(239, 68, 68, 0.2)",
            _ => "transparent"
        };
    }
}
