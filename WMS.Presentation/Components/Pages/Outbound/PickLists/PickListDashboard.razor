@page "/outbound/pick-lists"
@attribute [Authorize(Roles = "Admin,WarehouseManager,Picker,Viewer")]
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject UserManager<WMS.Domain.Entities.Identity.AppUser> UserManager

<PageTitle>WMS - Pick Lists</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px; display: flex; justify-content: space-between; align-items: center;">
    <div>
        <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Pick Lists Dashboard</h1>
        <p style="color: var(--text-muted); margin: 0; font-size: 15px;">Monitor picking activities, assign picking agents, and track order fulfillment status.</p>
    </div>
</div>

<!-- Tabs for Status Filtering -->
<div class="tabs-container" style="display: flex; gap: 8px; border-bottom: 1px solid var(--card-border); margin-bottom: 24px; padding-bottom: 8px;">
    @foreach (var tab in statusTabs)
    {
        <button class="tab-button @(SelectedTab == tab ? "active" : "")" @onclick="() => SelectTab(tab)">
            @tab
        </button>
    }
</div>

<!-- Search & Filter Controls -->
<div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 20px; margin-bottom: 24px; display: flex; gap: 16px; align-items: center;">
    <div class="input-group" style="flex: 1; max-width: 400px; display: flex; border: 1px solid var(--card-border); border-radius: 8px; overflow: hidden; background: rgba(15, 23, 42, 0.6);">
        <span style="display: flex; align-items: center; padding: 0 16px; color: var(--text-muted);">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </span>
        <input type="text" class="form-control" placeholder="Search PL number, SO, customer..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" style="border: none; background: transparent; color: var(--text-main); font-size: 14px; padding: 10px 0; outline: none; width: 100%;" />
    </div>
    <button class="btn" @onclick="Search" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(15, 23, 42, 0.4); font-weight: 500; padding: 10px 20px; border-radius: 8px;">
        Filter
    </button>
</div>

<!-- Errors -->
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
        <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="8" x2="12" y2="12"/>
            <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>@errorMessage</span>
    </div>
}

<!-- Main Table -->
@if (pickLists == null)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <DataTable TItem="WMS.Application.Features.PickList.DTOs.PickListDto"
               Items="pickLists"
               ColSpan="6"
               Page="Page"
               PageSize="PageSize"
               TotalCount="TotalCount"
               OnPageChanged="OnPageChanged">
        <HeaderTemplate>
            <th @onclick='() => Sort("PickListNumber")' style="cursor: pointer; user-select: none;">
                PL Number @GetSortIcon("PickListNumber")
            </th>
            <th @onclick='() => Sort("SONumber")' style="cursor: pointer; user-select: none;">
                Sales Order @GetSortIcon("SONumber")
            </th>
            <th @onclick='() => Sort("CustomerName")' style="cursor: pointer; user-select: none;">
                Customer @GetSortIcon("CustomerName")
            </th>
            <th>Assigned Picker</th>
            <th @onclick='() => Sort("Status")' style="cursor: pointer; user-select: none;">
                Status @GetSortIcon("Status")
            </th>
            <th class="text-end">Actions</th>
        </HeaderTemplate>
        <RowTemplate Context="pl">
            <td style="font-weight: 600; color: var(--text-main); font-family: monospace;">@pl.PickListNumber</td>
            <td style="font-family: monospace; font-size: 13px;">
                <a href="/outbound/sales-orders/@pl.SalesOrderId" style="color: var(--primary); text-decoration: none;">@pl.SONumber</a>
            </td>
            <td>@pl.CustomerName</td>
            <td style="color: var(--text-muted); font-size: 14px;">@(GetUserFriendlyName(pl.AssignedTo))</td>
            <td>
                <span class="badge" style="background-color: @GetStatusBgColor(pl.Status); color: @GetStatusTextColor(pl.Status); padding: 6px 12px; border-radius: 9999px; font-size: 11px; font-weight: 600; text-transform: uppercase; border: 1px solid @GetStatusBorderColor(pl.Status)">
                    @pl.Status
                </span>
            </td>
            <td class="text-end">
                <div style="display: inline-flex; gap: 8px;">
                    <a href="/outbound/pick-lists/@pl.Id" class="btn btn-sm" title="View Pick Details" style="padding: 6px 12px; border-radius: 6px; border: 1px solid var(--card-border); color: var(--text-muted); background: rgba(15, 23, 42, 0.2); text-decoration: none; font-size: 13px;">
                        View / Pick
                    </a>
                    @if (pl.Status == "Pending" || pl.Status == "InProgress")
                    {
                        <button class="btn btn-sm" @onclick="() => OpenAssignModal(pl.Id)" title="Assign Picker" style="padding: 6px 12px; border-radius: 6px; border: 1px solid var(--card-border); color: var(--text-main); background: rgba(255, 255, 255, 0.05); font-size: 13px; font-weight: 600;">
                            Assign
                        </button>
                    }
                </div>
            </td>
        </RowTemplate>
    </DataTable>
}

<!-- Assign Picker Modal Dialog -->
@if (showAssignModal)
{
    <AssignPicker PickListId="selectedPickListId" OnClose="CloseAssignModal" />
}

<style>
    .tab-button {
        background: transparent;
        border: none;
        color: var(--text-muted);
        padding: 8px 16px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.2s ease;
        border-radius: 6px;
    }

    .tab-button:hover {
        color: var(--text-main);
        background: rgba(255, 255, 255, 0.02);
    }

    .tab-button.active {
        color: var(--primary);
        background: var(--primary-light);
    }
</style>

@code {
    private readonly string[] statusTabs = { "All", "Pending", "InProgress", "Completed", "Cancelled" };
    private string SelectedTab = "All";

    private IReadOnlyList<WMS.Application.Features.PickList.DTOs.PickListDto>? pickLists;
    private string SearchTerm = string.Empty;
    private string SortColumn = "CreatedAt";
    private string SortOrder = "desc";
    private int Page = 1;
    private int PageSize = 10;
    private int TotalCount;
    private string? errorMessage;

    private bool showAssignModal = false;
    private Guid selectedPickListId;

    // Cache of users to avoid DB hits on table render
    private List<WMS.Domain.Entities.Identity.AppUser> allUsers = new();

    protected override async Task OnInitializedAsync()
    {
        allUsers = UserManager.Users.ToList();
        await LoadData();
    }

    private async Task LoadData()
    {
        errorMessage = null;
        var statusFilter = SelectedTab == "All" ? null : SelectedTab;
        var result = await Mediator.Send(new GetPickListsQuery(
            SearchTerm, statusFilter, SortColumn, SortOrder, Page, PageSize));
        
        if (result.IsSuccess)
        {
            pickLists = result.Value.Items;
            TotalCount = result.Value.TotalCount;
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private string GetUserFriendlyName(Guid? userId)
    {
        if (!userId.HasValue) return "Unassigned";
        var user = allUsers.FirstOrDefault(u => u.Id == userId.Value);
        return user != null ? (string.IsNullOrWhiteSpace(user.FullName) ? user.UserName! : user.FullName) : "Unknown Picker";
    }

    private async Task SelectTab(string tabName)
    {
        SelectedTab = tabName;
        Page = 1;
        await LoadData();
    }

    private async Task Search()
    {
        Page = 1;
        await LoadData();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        Page = newPage;
        await LoadData();
    }

    private async Task Sort(string column)
    {
        if (SortColumn == column)
        {
            SortOrder = SortOrder == "asc" ? "desc" : "asc";
        }
        else
        {
            SortColumn = column;
            SortOrder = "asc";
        }
        Page = 1;
        await LoadData();
    }

    private string GetSortIcon(string column)
    {
        if (SortColumn != column) return string.Empty;
        return SortOrder == "asc" ? "▲" : "▼";
    }

    private void OpenAssignModal(Guid pickListId)
    {
        selectedPickListId = pickListId;
        showAssignModal = true;
    }

    private async Task CloseAssignModal(bool refresh)
    {
        showAssignModal = false;
        if (refresh)
        {
            await LoadData();
        }
    }

    private string GetStatusBgColor(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "rgba(148, 163, 184, 0.1)",
            "inprogress" => "rgba(59, 130, 246, 0.1)",
            "completed" => "rgba(16, 185, 129, 0.1)",
            "cancelled" => "rgba(239, 68, 68, 0.1)",
            _ => "rgba(255, 255, 255, 0.05)"
        };
    }

    private string GetStatusTextColor(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "#94a3b8",
            "inprogress" => "#60a5fa",
            "completed" => "#34d399",
            "cancelled" => "#fca5a5",
            _ => "var(--text-muted)"
        };
    }

    private string GetStatusBorderColor(string status)
    {
        return status.ToLower() switch
        {
            "pending" => "rgba(148, 163, 184, 0.2)",
            "inprogress" => "rgba(59, 130, 246, 0.2)",
            "completed" => "rgba(16, 185, 129, 0.2)",
            "cancelled" => "rgba(239, 68, 68, 0.2)",
            _ => "transparent"
        };
    }
}
