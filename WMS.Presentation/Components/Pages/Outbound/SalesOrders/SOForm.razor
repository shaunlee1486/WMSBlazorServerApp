@page "/outbound/sales-orders/new"
@page "/outbound/sales-orders/{Id:guid}/edit"
@attribute [Authorize(Roles = "Admin,WarehouseManager")]
@inject IMediator Mediator
@inject IRepository<WMS.Domain.Entities.MasterData.Customer> CustomerRepository
@inject IRepository<WMS.Domain.Entities.MasterData.Product> ProductRepository
@inject ISalesOrderRepository SalesOrderRepository
@inject NavigationManager Navigation

<PageTitle>WMS - @(IsEditMode ? $"Edit Sales Order {soNumber}" : "New Sales Order")</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/outbound/sales-orders" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Sales Orders
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">
        @(IsEditMode ? $"Edit Sales Order {soNumber}" : "New Sales Order")
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">
        Draft and configure sales shipment orders for customers.
    </p>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
            <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>@errorMessage</span>
        </div>
    }

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px; align-items: start;">
        <!-- Left Panel: General info -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">General Details</h3>
            
            <div class="form-group">
                <label style="color: var(--text-muted); font-size: 14px; font-weight: 600;">Customer</label>
                <div style="margin-top: 8px;">
                    <select class="form-control" @bind="CustomerId" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; outline: none; width: 100%; cursor: pointer;">
                        <option value="">-- Select Customer --</option>
                        @if (customers != null)
                        {
                            foreach (var c in customers)
                            {
                                <option value="@c.Id">@c.Name (@c.Code)</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr; gap: 20px; margin-top: 20px;">
                <div class="form-group">
                    <label style="color: var(--text-muted); font-size: 14px; font-weight: 600;">Required Date</label>
                    <div style="margin-top: 8px;">
                        <input type="date" class="form-control" @bind="RequiredDate" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; outline: none; width: 100%; box-sizing: border-box;" />
                    </div>
                </div>
            </div>

            <div class="form-group" style="margin-top: 20px;">
                <label style="color: var(--text-muted); font-size: 14px; font-weight: 600;">Note / Remarks</label>
                <div style="margin-top: 8px;">
                    <textarea class="form-control" @bind="Note" rows="3" placeholder="Enter optional notes for shipping or details..." style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 12px 16px; font-size: 15px; width: 100%; box-sizing: border-box; outline: none; resize: vertical;"></textarea>
                </div>
            </div>
        </div>

        <!-- Right Panel: Summary -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; min-height: 195px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Order Summary</h3>
            
            <div style="display: flex; flex-direction: column; gap: 16px;">
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Status:</span>
                    <span style="font-weight: 600; color: #94a3b8;">Draft</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Total Line Items:</span>
                    <span style="font-weight: 600; color: var(--text-main);">@items.Count</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="color: var(--text-muted);">Total Value:</span>
                    <span style="font-weight: 700; color: var(--accent);">
                        $@TotalValue.ToString("N2")
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Items Section -->
    <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">
            <h3 style="font-size: 16px; font-weight: 700; margin: 0; color: var(--text-main);">Sales Order Items</h3>
            <button type="button" class="btn btn-sm" @onclick="AddItem" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(255, 255, 255, 0.05); padding: 8px 16px; border-radius: 6px; font-weight: 600; font-size: 13px; display: inline-flex; align-items: center; gap: 6px; cursor: pointer;">
                <svg style="width: 14px; height: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add Item
            </button>
        </div>

        <div style="overflow-x: auto;">
            <table class="wms-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr>
                        <th style="width: 45%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Product (SKU)</th>
                        <th style="width: 20%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Ordered Qty</th>
                        <th style="width: 20%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Unit Price ($)</th>
                        <th style="width: 20%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Total ($)</th>
                        <th style="width: 10%; padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!items.Any())
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 24px; color: var(--text-muted); border-bottom: 1px solid var(--card-border);">
                                No items added yet. Click "Add Item" to start drafting.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (int i = 0; i < items.Count; i++)
                        {
                            var index = i;
                            var item = items[index];
                            <tr>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                    <select class="form-control" @bind="item.ProductId" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 100%; cursor: pointer;">
                                        <option value="">-- Select Product --</option>
                                        @if (products != null)
                                        {
                                            foreach (var p in products)
                                            {
                                                <option value="@p.Id">@p.Name (@p.Code)</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right;">
                                    <input type="number" step="any" class="form-control" @bind="item.OrderedQty" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 120px; text-align: right; display: inline-block;" />
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right;">
                                    <input type="number" step="any" class="form-control" @bind="item.UnitPrice" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 8px 12px; font-size: 14px; outline: none; width: 120px; text-align: right; display: inline-block;" />
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right; font-weight: 600; color: var(--text-main);">
                                    $@((item.OrderedQty * item.UnitPrice).ToString("N2"))
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: center;">
                                    <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveItem(index)" style="padding: 6px 12px; border-radius: 6px; font-size: 13px; cursor: pointer; border: 1px solid rgba(239, 68, 68, 0.2); color: #fca5a5; background: rgba(239, 68, 68, 0.1);">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Actions -->
    <div style="display: flex; gap: 12px; justify-content: flex-end;">
        <a href="/outbound/sales-orders" class="btn" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(15, 23, 42, 0.4); padding: 10px 24px; border-radius: 8px; font-weight: 600; text-decoration: none; font-size: 15px;">
            Cancel
        </a>
        <button type="button" class="btn btn-primary" @onclick="SaveOrder" style="padding: 10px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; cursor: pointer;">
            Save Draft
        </button>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEditMode => Id.HasValue;
    private string soNumber = string.Empty;

    private bool loading = true;
    private string? errorMessage;

    private Guid? CustomerId { get; set; }
    private DateTime? RequiredDate { get; set; }
    private string? Note { get; set; }

    private List<FormItem> items = new();
    private IReadOnlyList<WMS.Domain.Entities.MasterData.Customer>? customers;
    private IReadOnlyList<WMS.Domain.Entities.MasterData.Product>? products;

    private decimal TotalValue => items.Sum(i => i.OrderedQty * i.UnitPrice);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            customers = await CustomerRepository.FindAsync(c => c.IsActive, CancellationToken.None);
            products = await ProductRepository.FindAsync(p => p.IsActive, CancellationToken.None);

            if (IsEditMode)
            {
                var result = await SalesOrderRepository.GetByIdWithItemsAsync(Id!.Value);
                if (result != null)
                {
                    if (result.Status != SalesOrderStatus.Draft)
                    {
                        Navigation.NavigateTo($"/outbound/sales-orders/{Id}");
                        return;
                    }

                    soNumber = result.SONumber;
                    CustomerId = result.CustomerId;
                    RequiredDate = result.RequiredDate;
                    Note = result.Note;

                    items = result.Items.Select(i => new FormItem
                    {
                        ProductId = i.ProductId,
                        OrderedQty = i.OrderedQty,
                        UnitPrice = i.UnitPrice
                    }).ToList();
                }
                else
                {
                    errorMessage = "Sales Order not found.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error initializing page: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void AddItem()
    {
        items.Add(new FormItem());
    }

    private void RemoveItem(int index)
    {
        if (index >= 0 && index < items.Count)
        {
            items.RemoveAt(index);
        }
    }

    private async Task SaveOrder()
    {
        errorMessage = null;

        if (!CustomerId.HasValue)
        {
            errorMessage = "Customer is required.";
            return;
        }

        if (!items.Any())
        {
            errorMessage = "At least one item is required.";
            return;
        }

        foreach (var item in items)
        {
            if (item.ProductId == Guid.Empty)
            {
                errorMessage = "All selected items must have a valid product.";
                return;
            }
            if (item.OrderedQty <= 0)
            {
                errorMessage = "All quantities must be greater than 0.";
                return;
            }
            if (item.UnitPrice < 0)
            {
                errorMessage = "Unit prices cannot be negative.";
                return;
            }
        }

        var commandItems = items.Select(i => new CreateSalesOrderItemInput(i.ProductId, i.OrderedQty, i.UnitPrice)).ToList();

        if (IsEditMode)
        {
            var result = await Mediator.Send(new UpdateSalesOrderCommand(Id!.Value, CustomerId.Value, RequiredDate, Note, commandItems));
            if (result.IsSuccess)
            {
                Navigation.NavigateTo($"/outbound/sales-orders/{Id}");
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        else
        {
            var result = await Mediator.Send(new CreateSalesOrderCommand(CustomerId.Value, RequiredDate, Note, commandItems));
            if (result.IsSuccess)
            {
                Navigation.NavigateTo($"/outbound/sales-orders/{result.Value}");
            }
            else
            {
                errorMessage = result.Error;
            }
        }
    }

    public class FormItem
    {
        public Guid ProductId { get; set; }
        public decimal OrderedQty { get; set; } = 1;
        public decimal UnitPrice { get; set; } = 0;
    }
}
