@page "/inbound/purchase-orders/{Id:guid}"
@attribute [Authorize(Roles = "Admin,WarehouseManager,Receiver,Viewer")]
@inject IMediator Mediator
@inject NavigationManager Navigation

<PageTitle>WMS - Purchase Order Details</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/inbound/purchase-orders" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Purchase Orders
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">
        Purchase Order Details
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">
        Overview, status history, and receipt details for this order.
    </p>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (po == null)
    {
        <div class="alert alert-danger">
            <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>Purchase order not found.</span>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                <svg class="alert-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>@errorMessage</span>
            </div>
        }

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px; align-items: start;">
            <!-- Left Panel: PO Info -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Order General Info</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">PO Number</span>
                        <div style="margin-top: 6px; font-family: monospace; font-size: 16px; font-weight: 700; color: var(--text-main);">@po.PONumber</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Supplier</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@po.SupplierName</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Order Date</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@po.OrderDate.ToLocalTime().ToString("yyyy-MM-dd")</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Expected Delivery</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@(po.ExpectedDate?.ToLocalTime().ToString("yyyy-MM-dd") ?? "N/A")</div>
                    </div>
                </div>

                <div style="margin-top: 24px;">
                    <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Note / Instructions</span>
                    <div style="margin-top: 8px; font-size: 15px; color: var(--text-main); background: rgba(15, 23, 42, 0.4); padding: 12px 16px; border-radius: 8px; border: 1px solid var(--card-border); line-height: 1.5;">
                        @(po.Note ?? "No notes provided.")
                    </div>
                </div>
            </div>

            <!-- Right Panel: Status Card -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Lifecycle Workflow</h3>
                
                <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="color: var(--text-muted);">Current Status:</span>
                        <span class="badge" style="background-color: @GetStatusBgColor(po.Status); color: @GetStatusTextColor(po.Status); padding: 6px 12px; border-radius: 9999px; font-size: 11px; font-weight: 700; text-transform: uppercase; border: 1px solid @GetStatusBorderColor(po.Status)">
                            @po.Status
                        </span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Total Order Value:</span>
                        <span style="font-weight: 700; color: var(--accent);">
                            $@TotalValue.ToString("N2")
                        </span>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @if (po.Status == "Draft")
                    {
                        <a href="/inbound/purchase-orders/@(po.Id)/edit" class="btn btn-primary" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px;">
                            <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                            Edit Draft
                        </a>
                        <button class="btn btn-primary" @onclick="ConfirmPO" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; width: 100%;">
                            Confirm Order
                        </button>
                    }
                    @if (po.Status == "Confirmed" || po.Status == "PartialReceived")
                    {
                        <button class="btn" @onclick="ReceiveGoods" style="padding: 12px; border-radius: 8px; border: none; background: linear-gradient(135deg, var(--success), #059669); color: #fff; font-weight: 600; font-size: 15px; width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2);">
                            <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                            Receive Goods
                        </button>
                        <button class="btn" @onclick="CancelPO" style="padding: 12px; border-radius: 8px; border: 1px solid var(--danger); color: var(--danger); background: rgba(239, 68, 68, 0.05); font-weight: 600; font-size: 15px; width: 100%;">
                            Cancel Purchase Order
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Items Table -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Purchase Items Ledger</h3>
            
            <DataTable TItem="WMS.Application.Features.PurchaseOrders.DTOs.PurchaseOrderItemDto"
                       Items="po.Items"
                       ColSpan="6"
                       Page="1"
                       PageSize="99999"
                       TotalCount="po.Items.Count"
                       OnPageChanged="_ => Task.CompletedTask">
                <HeaderTemplate>
                    <th>Product Code</th>
                    <th>Product Name</th>
                    <th style="text-align: right;">Ordered Qty</th>
                    <th style="text-align: right;">Received Qty</th>
                    <th style="text-align: right;">Unit Price ($)</th>
                    <th style="text-align: right;">Line Total ($)</th>
                </HeaderTemplate>
                <RowTemplate Context="item">
                    <td style="font-weight: 600; color: var(--text-main);">@item.ProductCode</td>
                    <td>@item.ProductName</td>
                    <td style="text-align: right; font-weight: 600;">@item.OrderedQty.ToString("N2")</td>
                    <td style="text-align: right; color: @(item.ReceivedQty == item.OrderedQty ? "var(--success)" : item.ReceivedQty > 0 ? "var(--accent)" : "var(--text-muted)"); font-weight: 600;">
                        @item.ReceivedQty.ToString("N2")
                    </td>
                    <td style="text-align: right;">$@item.UnitPrice.ToString("N2")</td>
                    <td style="text-align: right; font-weight: 600; color: var(--text-main);">$@item.LineTotal.ToString("N2")</td>
                </RowTemplate>
            </DataTable>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool loading = true;
    private WMS.Application.Features.PurchaseOrders.DTOs.PurchaseOrderDto? po;
    private string? errorMessage;

    private decimal TotalValue => po?.Items?.Sum(i => i.LineTotal) ?? 0m;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        var result = await Mediator.Send(new GetPurchaseOrderByIdQuery(Id));
        if (result.IsSuccess)
        {
            po = result.Value;
        }
        else
        {
            errorMessage = result.Error;
        }
        loading = false;
    }

    private async Task ConfirmPO()
    {
        errorMessage = null;
        var result = await Mediator.Send(new ConfirmPurchaseOrderCommand(Id));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private async Task CancelPO()
    {
        errorMessage = null;
        var result = await Mediator.Send(new CancelPurchaseOrderCommand(Id));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private void ReceiveGoods()
    {
        Navigation.NavigateTo($"/inbound/goods-receipts/new?poId={Id}");
    }

    private string GetStatusBgColor(string status)
    {
        return status.ToLower() switch
        {
            "draft" => "rgba(148, 163, 184, 0.1)",
            "confirmed" => "rgba(59, 130, 246, 0.1)",
            "partialreceived" => "rgba(245, 158, 11, 0.1)",
            "fullyreceived" => "rgba(16, 185, 129, 0.1)",
            "cancelled" => "rgba(239, 68, 68, 0.1)",
            _ => "rgba(255, 255, 255, 0.05)"
        };
    }

    private string GetStatusTextColor(string status)
    {
        return status.ToLower() switch
        {
            "draft" => "#94a3b8",
            "confirmed" => "#60a5fa",
            "partialreceived" => "#fbbf24",
            "fullyreceived" => "#34d399",
            "cancelled" => "#fca5a5",
            _ => "var(--text-muted)"
        };
    }

    private string GetStatusBorderColor(string status)
    {
        return status.ToLower() switch
        {
            "draft" => "rgba(148, 163, 184, 0.2)",
            "confirmed" => "rgba(59, 130, 246, 0.2)",
            "partialreceived" => "rgba(245, 158, 11, 0.2)",
            "fullyreceived" => "rgba(16, 185, 129, 0.2)",
            "cancelled" => "rgba(239, 68, 68, 0.2)",
            _ => "transparent"
        };
    }
}
