@page "/reports/stock-snapshot"
@attribute [Authorize(Roles = "Admin,WarehouseManager,Viewer")]
@inject IMediator Mediator
@inject IRepository<WMS.Domain.Entities.MasterData.Warehouse> WarehouseRepository
@inject IRepository<WMS.Domain.Entities.MasterData.Category> CategoryRepository
@inject IJSRuntime JS

<PageTitle>WMS - Stock Level Snapshot</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/reports" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Reports Portal
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Stock Level Snapshot</h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">Real-time stock balance overview across warehouses and categories.</p>
</div>

<!-- Filter Controls -->
<div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 20px; margin-bottom: 24px; display: grid; grid-template-columns: 1fr 1fr 1.5fr auto; gap: 16px; align-items: end;">
    <div class="form-group">
        <label style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase; margin-bottom: 8px; display: block;">Warehouse</label>
        <select class="form-control" @bind="SelectedWarehouseId" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 10px 16px; font-size: 14px; outline: none; width: 100%;">
            <option value="">All Warehouses</option>
            @if (warehouses != null)
            {
                foreach (var w in warehouses)
                {
                    <option value="@w.Id">@w.Name</option>
                }
            }
        </select>
    </div>

    <div class="form-group">
        <label style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase; margin-bottom: 8px; display: block;">Category</label>
        <select class="form-control" @bind="SelectedCategoryId" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 10px 16px; font-size: 14px; outline: none; width: 100%;">
            <option value="">All Categories</option>
            @if (categories != null)
            {
                foreach (var c in categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            }
        </select>
    </div>

    <div class="form-group">
        <label style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase; margin-bottom: 8px; display: block;">Search Product</label>
        <input type="text" class="form-control" placeholder="Search code, name, barcode..." @bind="SearchTerm" style="background-color: rgba(15, 23, 42, 0.6); border: 1px solid var(--card-border); color: var(--text-main); border-radius: 8px; padding: 10px 16px; font-size: 14px; outline: none; width: 100%; box-sizing: border-box;" />
    </div>

    <div style="display: flex; gap: 8px;">
        <button class="btn btn-primary" @onclick="LoadData" style="padding: 11px 24px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer;">
            Filter
        </button>
        <button class="btn" @onclick="ExportCsv" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(16, 185, 129, 0.1); border-color: rgba(16, 185, 129, 0.2); padding: 11px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; display: flex; align-items: center; gap: 8px; cursor: pointer;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
            </svg>
            CSV
        </button>
    </div>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (items == null || !items.Any())
    {
        <div style="background: rgba(30, 41, 59, 0.2); border: 1px solid var(--card-border); border-radius: 12px; padding: 48px; text-align: center; color: var(--text-muted);">
            No inventory matches found.
        </div>
    }
    else
    {
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
            <div style="overflow-x: auto;">
                <table class="wms-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Product</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Category</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Warehouse</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Location</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Total Qty</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Reserved Qty</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Available Qty</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var x in items)
                        {
                            <tr>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                    <span style="font-weight: 600; color: var(--text-main);">@x.ProductCode</span>
                                    <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">@x.ProductName</div>
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">@x.CategoryName</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">@x.WarehouseName</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); font-family: monospace;">@x.LocationBarcode</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right; font-weight: 600;">@x.Quantity</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right; color: var(--text-muted);">@x.ReservedQuantity</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right; font-weight: 700; color: var(--primary);">@x.AvailableQuantity</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    private bool loading = true;
    private IReadOnlyList<WMS.Domain.Entities.MasterData.Warehouse>? warehouses;
    private IReadOnlyList<WMS.Domain.Entities.MasterData.Category>? categories;
    private List<StockSnapshotDto>? items;

    private Guid? SelectedWarehouseId;
    private Guid? SelectedCategoryId;
    private string SearchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        warehouses = await WarehouseRepository.FindAsync(w => w.IsActive, CancellationToken.None);
        categories = await CategoryRepository.GetAllAsync(CancellationToken.None);
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        var result = await Mediator.Send(new GetStockSnapshotQuery(SelectedWarehouseId, SelectedCategoryId, SearchTerm));
        if (result.IsSuccess)
        {
            items = result.Value;
        }
        loading = false;
    }

    private async Task ExportCsv()
    {
        if (items == null || !items.Any()) return;

        var csv = new System.Text.StringBuilder();
        csv.AppendLine("Product Code,Product Name,Category,Warehouse,Location,Total Quantity,Reserved Quantity,Available Quantity");

        foreach (var x in items)
        {
            csv.AppendLine($"\"{x.ProductCode}\",\"{x.ProductName.Replace("\"", "\"\"")}\",\"{x.CategoryName}\",\"{x.WarehouseName}\",\"{x.LocationBarcode}\",{x.Quantity},{x.ReservedQuantity},{x.AvailableQuantity}");
        }

        var fileName = $"StockSnapshot_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", csv.ToString());
    }
}
