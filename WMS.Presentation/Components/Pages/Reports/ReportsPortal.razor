@page "/reports"
@attribute [Authorize]

<PageTitle>WMS - Reports Portal</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Reports Portal</h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">Generate, filter, and export detailed operations summaries.</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
    <!-- Card: Stock Snapshot -->
    <a href="/reports/stock-snapshot" style="text-decoration: none; display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 12px; color: var(--text-main); transition: all 0.2s ease;">
        <div style="background: rgba(79, 70, 229, 0.1); color: var(--primary); width: 48px; height: 48px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                <polyline points="2 17 12 22 22 17"/>
                <polyline points="2 12 12 17 22 12"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Stock Level Snapshot</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.5;">View current stock quantities, reserved counts, and warehouse bin distribution.</p>
        </div>
    </a>

    <!-- Card: Stock Movements -->
    <a href="/reports/movements" style="text-decoration: none; display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 12px; color: var(--text-main); transition: all 0.2s ease;">
        <div style="background: rgba(14, 165, 233, 0.1); color: var(--accent); width: 48px; height: 48px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Movement History Report</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.5;">Track historical logs of receipts, dispatches, transfers, and adjustments.</p>
        </div>
    </a>

    <!-- Card: Inbound Report -->
    <a href="/reports/inbound" style="text-decoration: none; display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 12px; color: var(--text-main); transition: all 0.2s ease;">
        <div style="background: rgba(16, 185, 129, 0.1); color: var(--success); width: 48px; height: 48px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="14 2 14 8 20 8"/>
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Inbound Fulfillment</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.5;">Goods receipts summary grouped by suppliers, date ranges, and expiry batches.</p>
        </div>
    </a>

    <!-- Card: Outbound Report -->
    <a href="/reports/outbound" style="text-decoration: none; display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 12px; color: var(--text-main); transition: all 0.2s ease;">
        <div style="background: rgba(244, 63, 94, 0.1); color: #f43f5e; width: 48px; height: 48px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"/>
                <circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Outbound Fulfillment</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.5;">Goods issues dispatch logs grouped by customers, timelines, and shipment codes.</p>
        </div>
    </a>

    <!-- Card: Stock Adjustments -->
    <a href="/reports/adjustments" style="text-decoration: none; display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 12px; color: var(--text-main); transition: all 0.2s ease;">
        <div style="background: rgba(245, 158, 11, 0.1); color: #f59e0b; width: 48px; height: 48px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 20h9"/>
                <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Stock Adjustments Ledger</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.5;">Auditable discrepancies report showing physical vs system values and reason codes.</p>
        </div>
    </a>

    <!-- Card: System Audit Log -->
    <a href="/reports/audit-logs" style="text-decoration: none; display: flex; gap: 16px; background: var(--card-bg); border: 1px solid var(--card-border); padding: 24px; border-radius: 12px; color: var(--text-main); transition: all 0.2s ease;">
        <div style="background: rgba(148, 163, 184, 0.1); color: #94a3b8; width: 48px; height: 48px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg style="width: 24px; height: 24px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
        </div>
        <div>
            <h3 style="font-size: 16px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">System Audit Trails</h3>
            <p style="font-size: 13px; color: var(--text-muted); margin: 0; line-height: 1.5;">Detailed audit trail logs containing exact record changes (create, edit, delete) with JSON diffs.</p>
        </div>
    </a>
</div>

<style>
    a:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.02) !important;
        border-color: var(--primary) !important;
    }
</style>
