@page "/inventory/movements"
@attribute [Authorize(Roles = "Admin,WarehouseManager,StockController,Receiver,Picker,Viewer")]
@inject IMediator Mediator

<PageTitle>WMS - Stock Movements Audit</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/inventory" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Stock Overview
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">Stock Movements</h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">Audit log of all material receipts, issues, transfers, and physical count adjustments.</p>
</div>

<!-- Search & Filtering -->
<div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 20px; margin-bottom: 24px; display: flex; gap: 16px; align-items: center;">
    <div class="input-group" style="flex: 1; max-width: 400px; display: flex; border: 1px solid var(--card-border); border-radius: 8px; overflow: hidden; background: rgba(15, 23, 42, 0.6);">
        <span style="display: flex; align-items: center; padding: 0 16px; color: var(--text-muted);">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/>
                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
        </span>
        <input type="text" class="form-control" placeholder="Search SKU, name, reference, location..." @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleKeyUp" style="border: none; background: transparent; color: var(--text-main); font-size: 14px; padding: 10px 0; outline: none; width: 100%;" />
    </div>
    <button class="btn" @onclick="Search" style="border: 1px solid var(--card-border); color: var(--text-main); background: rgba(15, 23, 42, 0.4); font-weight: 500; padding: 10px 20px; border-radius: 8px;">
        Filter
    </button>
</div>

<!-- Main Table -->
@if (movements == null)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <DataTable TItem="WMS.Application.Features.Stock.DTOs.StockMovementDto"
               Items="movements"
               ColSpan="8"
               Page="Page"
               PageSize="PageSize"
               TotalCount="TotalCount"
               OnPageChanged="OnPageChanged">
        <HeaderTemplate>
            <th @onclick='() => Sort("CreatedAt")' style="cursor: pointer; user-select: none;">
                Date @GetSortIcon("CreatedAt")
            </th>
            <th @onclick='() => Sort("ProductCode")' style="cursor: pointer; user-select: none;">
                Product Code @GetSortIcon("ProductCode")
            </th>
            <th>Product Name</th>
            <th @onclick='() => Sort("MovementType")' style="cursor: pointer; user-select: none;">
                Type @GetSortIcon("MovementType")
            </th>
            <th>From Location</th>
            <th>To Location</th>
            <th @onclick='() => Sort("Quantity")' style="cursor: pointer; user-select: none; text-align: right;">
                Qty @GetSortIcon("Quantity")
            </th>
            <th @onclick='() => Sort("ReferenceNo")' style="cursor: pointer; user-select: none;">
                Reference @GetSortIcon("ReferenceNo")
            </th>
        </HeaderTemplate>
        <RowTemplate Context="m">
            <td style="color: var(--text-muted); font-size: 13px;">@m.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
            <td style="font-weight: 600; color: var(--text-main);">@m.ProductCode</td>
            <td>@m.ProductName</td>
            <td>
                <span class="badge" style="background-color: @GetMovementTypeColor(m.MovementType); color: #fff; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase;">
                    @m.MovementType
                </span>
            </td>
            <td style="font-family: monospace; font-size: 13px; color: var(--text-muted);">@(m.FromLocationBarcode ?? "-")</td>
            <td style="font-family: monospace; font-size: 13px; color: var(--text-muted);">@(m.ToLocationBarcode ?? "-")</td>
            <td style="text-align: right; font-weight: 600; color: @(GetQuantityColor(m.MovementType));">
                @(GetQuantityPrefix(m.MovementType))@m.Quantity.ToString("N2")
            </td>
            <td>
                <span style="font-family: monospace; font-size: 13px; background: rgba(255,255,255,0.05); padding: 2px 6px; border-radius: 4px;">
                    @(m.ReferenceNo ?? "-")
                </span>
            </td>
        </RowTemplate>
    </DataTable>
}

@code {
    private IReadOnlyList<WMS.Application.Features.Stock.DTOs.StockMovementDto>? movements;
    private string SearchTerm = string.Empty;
    private string SortColumn = "CreatedAt";
    private string SortOrder = "desc";
    private int Page = 1;
    private int PageSize = 10;
    private int TotalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var result = await Mediator.Send(new GetStockMovementsQuery(
            SearchTerm, SortColumn, SortOrder, Page, PageSize));
        
        if (result.IsSuccess)
        {
            movements = result.Value.Items;
            TotalCount = result.Value.TotalCount;
        }
    }

    private async Task Search()
    {
        Page = 1;
        await LoadData();
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Search();
        }
    }

    private async Task OnPageChanged(int newPage)
    {
        Page = newPage;
        await LoadData();
    }

    private async Task Sort(string column)
    {
        if (SortColumn == column)
        {
            SortOrder = SortOrder == "asc" ? "desc" : "asc";
        }
        else
        {
            SortColumn = column;
            SortOrder = "asc";
        }
        Page = 1;
        await LoadData();
    }

    private string GetSortIcon(string column)
    {
        if (SortColumn != column) return string.Empty;
        return SortOrder == "asc" ? "▲" : "▼";
    }

    private string GetMovementTypeColor(string type)
    {
        return type.ToLower() switch
        {
            "receipt" => "#10b981",    // success green
            "issue" => "#ef4444",      // danger red
            "transfer" => "#f59e0b",   // warning amber
            "adjustment" => "#3b82f6", // info blue
            _ => "#6b7280"             // gray
        };
    }

    private string GetQuantityPrefix(string type)
    {
        return type.ToLower() switch
        {
            "receipt" => "+",
            "issue" => "-",
            _ => ""
        };
    }

    private string GetQuantityColor(string type)
    {
        return type.ToLower() switch
        {
            "receipt" => "var(--success)",
            "issue" => "var(--danger)",
            _ => "var(--text-main)"
        };
    }
}
