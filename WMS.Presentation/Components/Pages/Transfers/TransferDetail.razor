@page "/transfers/{Id:guid}"
@attribute [Authorize(Roles = "Admin,WarehouseManager,Receiver,Picker,Viewer")]
@inject IMediator Mediator
@inject NavigationManager Navigation

<PageTitle>WMS - Transfer Order Details</PageTitle>

<div class="dashboard-header" style="margin-bottom: 32px;">
    <div style="display: flex; gap: 8px; align-items: center; margin-bottom: 8px;">
        <a href="/transfers" style="color: var(--text-muted); text-decoration: none; display: flex; align-items: center; gap: 4px; font-size: 14px;">
            <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Transfer Orders
        </a>
    </div>
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0; color: var(--text-main);">
        Transfer Order Details
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 15px;">
        Overview, status history, and actions for this inter-warehouse transfer.
    </p>
</div>

@if (loading)
{
    <div style="display: flex; justify-content: center; align-items: center; padding: 80px 0;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: var(--primary) !important;">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (transfer == null)
    {
        <div class="alert alert-danger" style="display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
            <svg class="alert-icon" style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
            <span>Transfer order not found.</span>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger" style="margin-bottom: 24px; display: flex; align-items: center; gap: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); padding: 16px; border-radius: 8px; color: #fca5a5;">
                <svg class="alert-icon" style="width: 20px; height: 20px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <span>@errorMessage</span>
            </div>
        }

        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; margin-bottom: 24px; align-items: start;">
            <!-- Left Panel: Transfer Info -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Transfer General Info</h3>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">TO Number</span>
                        <div style="margin-top: 6px; font-family: monospace; font-size: 16px; font-weight: 700; color: var(--text-main);">@transfer.TONumber</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Requested Date</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@transfer.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Source Warehouse</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@transfer.FromWarehouseName</div>
                    </div>
                    <div>
                        <span style="color: var(--text-muted); font-size: 12px; font-weight: 600; text-transform: uppercase;">Destination Warehouse</span>
                        <div style="margin-top: 6px; font-size: 15px; color: var(--text-main);">@transfer.ToWarehouseName</div>
                    </div>
                </div>
            </div>

            <!-- Right Panel: Status Card -->
            <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px;">
                <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Lifecycle Workflow</h3>
                
                <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="color: var(--text-muted);">Current Status:</span>
                        <span class="badge" style="background-color: @GetStatusBgColor(transfer.Status); color: @GetStatusTextColor(transfer.Status); padding: 6px 12px; border-radius: 9999px; font-size: 11px; font-weight: 700; text-transform: uppercase; border: 1px solid @GetStatusBorderColor(transfer.Status)">
                            @transfer.Status
                        </span>
                    </div>
                    <div style="display: flex; justify-content: space-between;">
                        <span style="color: var(--text-muted);">Total Items:</span>
                        <span style="font-weight: 700; color: var(--text-main);">@transfer.Items.Count</span>
                    </div>
                </div>

                <div style="display: flex; flex-direction: column; gap: 12px;">
                    @if (transfer.Status == "Draft")
                    {
                        <a href="/transfers/@(transfer.Id)/edit" class="btn" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; border: 1px solid var(--card-border); color: var(--text-main); background: rgba(255, 255, 255, 0.05); text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 8px;">
                            <svg style="width: 18px; height: 18px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                            </svg>
                            Edit Draft
                        </a>
                        <button class="btn btn-primary" @onclick="ApproveTO" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; width: 100%;">
                            Approve Order
                        </button>
                    }
                    @if (transfer.Status == "Approved")
                    {
                        <button class="btn btn-primary" @onclick="StartTO" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; width: 100%; background-color: #3b82f6;">
                            Ship (Start Transit)
                        </button>
                    }
                    @if (transfer.Status == "InTransit")
                    {
                        <button class="btn btn-primary" @onclick="CompleteTO" style="padding: 12px; border-radius: 8px; font-weight: 600; font-size: 15px; width: 100%; background-color: #10b981;">
                            Receive Transfer
                        </button>
                    }
                    @if (transfer.Status == "Draft" || transfer.Status == "Approved" || transfer.Status == "InTransit")
                    {
                        <button class="btn" @onclick="CancelTO" style="padding: 12px; border-radius: 8px; border: 1px solid var(--danger); color: var(--danger); background: rgba(239, 68, 68, 0.05); font-weight: 600; font-size: 15px; width: 100%;">
                            Cancel Transfer
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Transfer Line Items -->
        <div style="background: rgba(30, 41, 59, 0.4); border: 1px solid var(--card-border); border-radius: 12px; padding: 24px; margin-bottom: 24px;">
            <h3 style="font-size: 16px; font-weight: 700; margin-top: 0; margin-bottom: 20px; color: var(--text-main); border-bottom: 1px solid var(--card-border); padding-bottom: 12px;">Transfer Line Items</h3>
            <div style="overflow-x: auto;">
                <table class="wms-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                    <thead>
                        <tr>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Product</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Source Location</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border);">Destination Location</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: right;">Quantity</th>
                            <th style="padding: 12px 16px; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; border-bottom: 1px solid var(--card-border); text-align: center;">Item Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in transfer.Items)
                        {
                            <tr>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border);">
                                    <span style="font-weight: 600; color: var(--text-main);">@item.ProductCode</span>
                                    <div style="font-size: 12px; color: var(--text-muted); margin-top: 2px;">@item.ProductName</div>
                                </td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); font-family: monospace;">@item.FromLocationBarcode</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); font-family: monospace;">@item.ToLocationBarcode</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: right; font-weight: 600;">@item.Qty</td>
                                <td style="padding: 12px 16px; border-bottom: 1px solid var(--card-border); text-align: center;">
                                    <span class="badge" style="padding: 4px 8px; border-radius: 4px; font-size: 10px; font-weight: 600; background-color: rgba(255,255,255,0.05); color: var(--text-muted);">
                                        @item.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool loading = true;
    private string? errorMessage;
    private TransferOrderDto? transfer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            loading = true;
            errorMessage = null;
            var result = await Mediator.Send(new GetTransferOrderByIdQuery(Id));
            if (result.IsSuccess)
            {
                transfer = result.Value;
            }
            else
            {
                errorMessage = result.Error;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ApproveTO()
    {
        errorMessage = null;
        var result = await Mediator.Send(new ApproveTransferOrderCommand(Id));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private async Task StartTO()
    {
        errorMessage = null;
        var result = await Mediator.Send(new StartTransferCommand(Id));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private async Task CompleteTO()
    {
        errorMessage = null;
        var result = await Mediator.Send(new CompleteTransferCommand(Id));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private async Task CancelTO()
    {
        errorMessage = null;
        var result = await Mediator.Send(new CancelTransferCommand(Id));
        if (result.IsSuccess)
        {
            await LoadData();
        }
        else
        {
            errorMessage = result.Error;
        }
    }

    private string GetStatusBgColor(string status)
    {
        return status.ToLower() switch
        {
            "draft" => "rgba(148, 163, 184, 0.1)",
            "approved" => "rgba(59, 130, 246, 0.1)",
            "intransit" => "rgba(245, 158, 11, 0.1)",
            "completed" => "rgba(16, 185, 129, 0.1)",
            "cancelled" => "rgba(239, 68, 68, 0.1)",
            _ => "rgba(255, 255, 255, 0.05)"
        };
    }

    private string GetStatusTextColor(string status)
    {
        return status.ToLower() switch
        {
            "draft" => "#94a3b8",
            "approved" => "#60a5fa",
            "intransit" => "#fbbf24",
            "completed" => "#34d399",
            "cancelled" => "#fca5a5",
            _ => "var(--text-muted)"
        };
    }

    private string GetStatusBorderColor(string status)
    {
        return status.ToLower() switch
        {
            "draft" => "rgba(148, 163, 184, 0.2)",
            "approved" => "rgba(59, 130, 246, 0.2)",
            "intransit" => "rgba(245, 158, 11, 0.2)",
            "completed" => "rgba(16, 185, 129, 0.2)",
            "cancelled" => "rgba(239, 68, 68, 0.2)",
            _ => "transparent"
        };
    }
}
